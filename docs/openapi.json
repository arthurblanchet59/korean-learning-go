{
  "openapi": "3.0.3",
  "info": {
    "title": "Korean Learning API",
    "description": "API REST Gin/SQLite pour apprendre le coreen avec decks, flashcards, revision espacee et authentification JWT.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Serveur local go run ."
    }
  ],
  "tags": [
    { "name": "Health", "description": "Etat du serveur" },
    { "name": "Auth", "description": "Inscription, connexion et profil utilisateur" },
    { "name": "Admin", "description": "Operations reservees aux administrateurs" },
    { "name": "Decks", "description": "Gestion CRUD des decks" },
    { "name": "Cards", "description": "Gestion CRUD des flashcards" },
    { "name": "Study", "description": "Revision espacee et reponses aux cartes" },
    { "name": "Search", "description": "Recherche sur les ressources" },
    { "name": "Stats", "description": "Statistiques de revision" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Verifier que le serveur repond",
        "responses": {
          "200": {
            "description": "Serveur disponible",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },
    "/user/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Creer un utilisateur",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" }
            }
          }
        },
        "responses": {
          "201": { "$ref": "#/components/responses/AuthResult" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/user/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Connecter un utilisateur",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/AuthResult" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/user/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Lire son profil",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Profil public",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PublicUser" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "tags": ["Auth"],
        "summary": "Mettre a jour son profil",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateUserRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profil mis a jour",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PublicUser" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/admin/users/{id}": {
      "put": {
        "tags": ["Admin"],
        "summary": "Modifier un utilisateur non admin",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateUserRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Utilisateur modifie",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PublicUser" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/admin/reset": {
      "post": {
        "tags": ["Admin"],
        "summary": "Reinitialiser la base de donnees depuis l'espace admin",
        "description": "Supprime decks, cartes, reviews et utilisateurs non admin. Les administrateurs sont conserves.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/ResetResult" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "Reinitialiser la base de donnees depuis l'espace admin",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/ResetResult" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/reset": {
      "post": {
        "tags": ["Admin"],
        "summary": "Reinitialiser la base de donnees",
        "description": "Supprime decks, cartes, reviews et utilisateurs non admin. Les administrateurs sont conserves.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/ResetResult" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "Reinitialiser la base de donnees",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/ResetResult" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/decks": {
      "get": {
        "tags": ["Decks"],
        "summary": "Lister tous les decks",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Liste des decks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Deck" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Decks"],
        "summary": "Creer un deck",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeckRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Deck cree",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Deck" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/decks/search": {
      "get": {
        "tags": ["Decks", "Search"],
        "summary": "Rechercher des decks sur tous leurs champs",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/Query" }],
        "responses": {
          "200": {
            "description": "Decks trouves",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Deck" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/decks/{id}": {
      "get": {
        "tags": ["Decks"],
        "summary": "Afficher un deck par ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "200": {
            "description": "Deck",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Deck" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Decks"],
        "summary": "Mettre a jour un deck",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeckPatchRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deck modifie",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Deck" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Decks"],
        "summary": "Supprimer un deck",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "204": { "description": "Deck supprime" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/decks/bulk": {
      "put": {
        "tags": ["Decks"],
        "summary": "Mettre a jour plusieurs decks par ID",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BulkDeckUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Decks modifies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Deck" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "delete": {
        "tags": ["Decks"],
        "summary": "Supprimer plusieurs decks par ID",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BulkDeleteRequest" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/DeleteCount" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/cards": {
      "get": {
        "tags": ["Cards"],
        "summary": "Lister toutes les cartes",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Liste des cartes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Card" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Cards"],
        "summary": "Creer une carte",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CardRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Carte creee",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Card" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/cards/search": {
      "get": {
        "tags": ["Cards", "Search"],
        "summary": "Rechercher des cartes sur tous leurs champs",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/Query" }],
        "responses": {
          "200": {
            "description": "Cartes trouvees",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Card" }
                }
              }
            }
          }
        }
      }
    },
    "/api/cards/difficult": {
      "get": {
        "tags": ["Cards", "Stats"],
        "summary": "Lister les cartes difficiles",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Cartes avec au moins deux echecs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Card" }
                }
              }
            }
          }
        }
      }
    },
    "/api/cards/{id}": {
      "get": {
        "tags": ["Cards"],
        "summary": "Afficher une carte par ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "200": {
            "description": "Carte",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Card" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Cards"],
        "summary": "Mettre a jour une carte",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CardPatchRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Carte modifiee",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Card" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Cards"],
        "summary": "Supprimer une carte",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "204": { "description": "Carte supprimee" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/cards/bulk": {
      "put": {
        "tags": ["Cards"],
        "summary": "Mettre a jour plusieurs cartes par ID",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BulkCardUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cartes modifiees",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Card" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "delete": {
        "tags": ["Cards"],
        "summary": "Supprimer plusieurs cartes par ID",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BulkDeleteRequest" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/DeleteCount" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/search": {
      "get": {
        "tags": ["Search"],
        "summary": "Recherche globale decks et cartes",
        "description": "Recherche la sous-chaine dans les champs des decks et des cartes.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/Query" }],
        "responses": {
          "200": {
            "description": "Resultats groupes par ressource",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResult" }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "tags": ["Search"],
        "summary": "Alias de recherche globale",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/Query" }],
        "responses": {
          "200": {
            "description": "Resultats groupes par ressource",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResult" }
              }
            }
          }
        }
      }
    },
    "/api/reviews/due": {
      "get": {
        "tags": ["Study"],
        "summary": "Lister les cartes dues",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Cartes a reviser",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Card" }
                }
              }
            }
          }
        }
      }
    },
    "/study/today": {
      "get": {
        "tags": ["Study"],
        "summary": "Alias pour les cartes a reviser aujourd'hui",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Cartes a reviser",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Card" }
                }
              }
            }
          }
        }
      }
    },
    "/api/reviews/{id}/answer": {
      "post": {
        "tags": ["Study"],
        "summary": "Repondre a une carte",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AnswerRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Review creee",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Review" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/study/cards/{id}/answer": {
      "post": {
        "tags": ["Study"],
        "summary": "Alias pour repondre a une carte",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AnswerRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Review creee",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Review" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/stats": {
      "get": {
        "tags": ["Stats"],
        "summary": "Afficher les statistiques",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Statistiques",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StudyStats" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "ID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "Query": {
        "name": "query",
        "in": "query",
        "required": true,
        "schema": { "type": "string" },
        "description": "Sous-chaine recherchee dans tous les champs indexes par la route."
      }
    },
    "responses": {
      "AuthResult": {
        "description": "JWT et utilisateur public",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/AuthResult" }
          }
        }
      },
      "ResetResult": {
        "description": "Base reinitialisee",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ResetResponse" }
          }
        }
      },
      "DeleteCount": {
        "description": "Nombre d'elements supprimes",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/DeleteCount" }
          }
        }
      },
      "BadRequest": {
        "description": "Requete invalide",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "JWT manquant ou invalide",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Forbidden": {
        "description": "Droits insuffisants",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "Ressource introuvable",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Conflict": {
        "description": "Conflit de donnees",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "ok" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        },
        "required": ["error"]
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": { "type": "string", "minLength": 2, "maxLength": 80, "example": "Arthur" },
          "email": { "type": "string", "format": "email", "example": "arthur@example.com" },
          "password": { "type": "string", "format": "password", "minLength": 8, "example": "password123" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email", "example": "admin@korean.local" },
          "password": { "type": "string", "format": "password", "example": "admin123" }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 2, "maxLength": 80 },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password", "minLength": 8 }
        }
      },
      "PublicUser": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "isAdmin": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "AuthResult": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "description": "JWT a fournir dans Authorization: Bearer <token>" },
          "user": { "$ref": "#/components/schemas/PublicUser" }
        }
      },
      "Deck": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "DeckRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 120, "example": "Vocabulaire quotidien" },
          "description": { "type": "string", "maxLength": 500, "example": "Mots utiles pour les conversations simples." }
        }
      },
      "DeckPatchRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 120 },
          "description": { "type": "string", "maxLength": 500 }
        }
      },
      "Card": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "deckId": { "type": "string" },
          "kind": { "type": "string", "enum": ["vocabulary", "phrase", "hangul"] },
          "korean": { "type": "string" },
          "translation": { "type": "string" },
          "romanization": { "type": "string" },
          "exampleKorean": { "type": "string" },
          "exampleTranslation": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "createdAt": { "type": "string", "format": "date-time" },
          "reviewState": { "$ref": "#/components/schemas/ReviewState" }
        }
      },
      "CardRequest": {
        "type": "object",
        "required": ["deckId", "kind", "korean", "translation"],
        "properties": {
          "deckId": { "type": "string", "example": "deck-basic-korean" },
          "kind": { "type": "string", "enum": ["vocabulary", "phrase", "hangul"], "example": "vocabulary" },
          "korean": { "type": "string", "example": "물" },
          "translation": { "type": "string", "example": "eau" },
          "romanization": { "type": "string", "example": "mul" },
          "exampleKorean": { "type": "string", "example": "물을 마셔요." },
          "exampleTranslation": { "type": "string", "example": "Je bois de l'eau." },
          "tags": { "type": "array", "items": { "type": "string" }, "example": ["base", "nourriture"] }
        }
      },
      "CardPatchRequest": {
        "type": "object",
        "properties": {
          "deckId": { "type": "string" },
          "kind": { "type": "string", "enum": ["vocabulary", "phrase", "hangul"] },
          "korean": { "type": "string" },
          "translation": { "type": "string" },
          "romanization": { "type": "string" },
          "exampleKorean": { "type": "string" },
          "exampleTranslation": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ReviewState": {
        "type": "object",
        "properties": {
          "nextReviewAt": { "type": "string", "format": "date-time" },
          "lastReviewAt": { "type": "string", "format": "date-time" },
          "intervalDays": { "type": "integer" },
          "easeFactor": { "type": "number" },
          "reviewCount": { "type": "integer" },
          "lapseCount": { "type": "integer" }
        }
      },
      "Review": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "cardId": { "type": "string" },
          "rating": { "type": "string", "enum": ["again", "hard", "good", "easy"] },
          "reviewedAt": { "type": "string", "format": "date-time" },
          "previous": { "$ref": "#/components/schemas/ReviewState" },
          "next": { "$ref": "#/components/schemas/ReviewState" }
        }
      },
      "AnswerRequest": {
        "type": "object",
        "required": ["rating"],
        "properties": {
          "rating": { "type": "string", "enum": ["again", "hard", "good", "easy"], "example": "good" }
        }
      },
      "StudyStats": {
        "type": "object",
        "properties": {
          "totalCards": { "type": "integer" },
          "dueCards": { "type": "integer" },
          "newCards": { "type": "integer" },
          "difficultCards": { "type": "integer" }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "decks": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Deck" }
          },
          "cards": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Card" }
          }
        }
      },
      "BulkDeleteRequest": {
        "type": "object",
        "required": ["ids"],
        "properties": {
          "ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      },
      "BulkDeckUpdateRequest": {
        "type": "object",
        "required": ["ids", "patch"],
        "properties": {
          "ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "patch": { "$ref": "#/components/schemas/DeckPatchRequest" }
        }
      },
      "BulkCardUpdateRequest": {
        "type": "object",
        "required": ["ids", "patch"],
        "properties": {
          "ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "patch": { "$ref": "#/components/schemas/CardPatchRequest" }
        }
      },
      "DeleteCount": {
        "type": "object",
        "properties": {
          "deleted": { "type": "integer" }
        }
      },
      "ResetResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "database reset completed" },
          "result": {
            "type": "object",
            "properties": {
              "deletedReviews": { "type": "integer" },
              "deletedCards": { "type": "integer" },
              "deletedDecks": { "type": "integer" },
              "deletedUsers": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
